<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="Dynamiczna_lista_zakupow.ShoppingListApp">
  <grid id="27dc6" binding="panel1" default-binding="true" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="48d51" binding="centerPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
        <constraints border-constraint="Center"/>
        <properties/>
        <border type="none"/>
        <children>
          <scrollpane id="8abc4">
            <constraints border-constraint="Center"/>
            <properties/>
            <border type="none"/>
            <children>
              <component id="74b32" class="javax.swing.JList" binding="itemsList">
                <constraints/>
                <properties/>
              </component>
            </children>
          </scrollpane>
        </children>
      </grid>
      <grid id="62120" binding="topPanel" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="1">
        <constraints border-constraint="North"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="2ab7d" class="javax.swing.JTextField" binding="itemInput">
            <constraints/>
            <properties>
              <columns value="25"/>
            </properties>
          </component>
          <component id="2d954" class="javax.swing.JButton" binding="addButton">
            <constraints/>
            <properties>
              <text value="Dodaj"/>
            </properties>
          </component>
          <component id="673c6" class="javax.swing.JButton" binding="deleteButton">
            <constraints/>
            <properties>
              <text value="Usuń zaznaczone"/>
            </properties>
          </component>
        </children>
      </grid>
    </children>
  </grid>
</form>
